# ── Required (app) ───────────────────────────────────────────────────────────
# Mapbox public access token (pk.*). Exposed to the browser by design.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Supabase project, browser-safe values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Required only for scripts/geocode-riads.ts ───────────────────────────────
# Service role key to bypass RLS when updating tripadvisor_listings_raw.
# NEVER expose to the browser. NEVER set as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: server-side Mapbox token for the geocoding script. If unset, the
# script falls back to NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN.
MAPBOX_ACCESS_TOKEN=
